-- 🚀 SQL Learning Journey — Day 3
-- Topic: AND, OR, NOT (Multiple Conditions)

-- 🎯 Goal:
-- Learn how to apply multiple conditions in filtering

-- 📊 Sample Table: students
-- Columns: id, name, marks, city

--------------------------------------------------
-- 🔹 1. AND Operator (All conditions must be TRUE)
--------------------------------------------------

-- Students with marks > 70 AND from 'Delhi'
SELECT *
FROM students
WHERE marks > 70 AND city = 'Delhi';

--------------------------------------------------
-- 🔹 2. OR Operator (At least one condition TRUE)
--------------------------------------------------

-- Students with marks > 90 OR from 'Mumbai'
SELECT *
FROM students
WHERE marks > 90 OR city = 'Mumbai';

--------------------------------------------------
-- 🔹 3. NOT Operator (Negation)
--------------------------------------------------

-- Students NOT from 'Jaipur'
SELECT *
FROM students
WHERE NOT city = 'Jaipur';

-- OR (better practice)
SELECT *
FROM students
WHERE city != 'Jaipur';

--------------------------------------------------
-- 🔹 4. Combining AND + OR (IMPORTANT)
--------------------------------------------------

-- Students from Delhi with marks > 80 OR from Mumbai
SELECT *
FROM students
WHERE (city = 'Delhi' AND marks > 80)
   OR city = 'Mumbai';

--------------------------------------------------
-- ⚠️ Priority Rule (VERY IMPORTANT)
--------------------------------------------------

-- AND has higher priority than OR

-- Wrong understanding example:
SELECT *
FROM students
WHERE city = 'Delhi' AND marks > 80 OR city = 'Mumbai';

-- Always use brackets to avoid confusion!

--------------------------------------------------
-- 🧠 Key Concepts:
--------------------------------------------------
-- AND → all conditions must be true
-- OR → any condition true
-- NOT → reverse condition
-- Use brackets () for clarity

